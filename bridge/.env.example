# Bright Data Scraping Browser (Browser API) WSS endpoint
# Format: wss://brd-customer-<CUSTOMER_ID>-zone-<ZONE_NAME>:<ZONE_PASSWORD>@brd.superproxy.io:9222
# Get yours at https://brightdata.com/cp/zones — create a "browser_api" zone first.
BRIGHTDATA_BROWSER_WSS=wss://brd-customer-REPLACE_ME-zone-REPLACE_ME:REPLACE_ME@brd.superproxy.io:9222

# HTTP port the bridge listens on (matched by the Cloudflare Tunnel route)
BRIDGE_PORT=8081

# Optional: if set, the bridge requires Authorization: Bearer <token> on /render and /serp.
# Generate with: openssl rand -hex 32
BRIDGE_AUTH_TOKEN=
